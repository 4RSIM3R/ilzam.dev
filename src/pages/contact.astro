---
import ContentLayout from '@/layouts/content-layout.astro'
import { CalEmbed } from '@/components/cal-embed'
---

<ContentLayout
	title="Contact — Ilzam"
	description="Book a free intro call, send an email, or connect on GitHub and LinkedIn. Fractional CTO for early-stage founders, based in Indonesia, working globally."
>
	<h1 class="text-3xl font-light leading-tight tracking-tight md:text-4xl">
		Let's talk
	</h1>
	<p class="mt-3 text-muted-foreground">
		Book a free 30-minute intro call. No pitch, no pressure — just a real
		conversation about what you're building.
	</p>

	<!-- Cal.com embed -->
	<div class="mt-10 min-h-[600px]">
		<CalEmbed client:load />
	</div>

	<!-- Other ways to reach me -->
	<section class="mt-12 border-t pt-8">
		<h2 class="text-sm font-medium uppercase tracking-wider text-muted-foreground">
			Other ways to reach me
		</h2>
		<div class="mt-4 grid gap-4 md:grid-cols-3">
			<a
				href="mailto:ilzammulkhaq85@gmail.com"
				class="group rounded-lg border p-5 transition-shadow hover:shadow-md"
			>
				<p class="font-semibold group-hover:underline">Email</p>
				<p class="mt-1 text-sm text-muted-foreground">ilzammulkhaq85@gmail.com</p>
			</a>
			<a
				href="https://github.com/4RSIM3R/"
				target="_blank"
				rel="noopener noreferrer"
				class="group rounded-lg border p-5 transition-shadow hover:shadow-md"
			>
				<p class="font-semibold group-hover:underline">GitHub</p>
				<p class="mt-1 text-sm text-muted-foreground">github.com/4RSIM3R</p>
			</a>
			<a
				href="https://www.linkedin.com/in/ilzam-mulkhaq/"
				target="_blank"
				rel="noopener noreferrer"
				class="group rounded-lg border p-5 transition-shadow hover:shadow-md"
			>
				<p class="font-semibold group-hover:underline">LinkedIn</p>
				<p class="mt-1 text-sm text-muted-foreground">linkedin.com/in/ilzam-mulkhaq</p>
			</a>
		</div>
	</section>

	<section class="mt-8">
		<p class="text-sm text-muted-foreground">
			Based in Pasuruan, East Java, Indonesia. Working remotely with clients in the
			US, Europe, and Southeast Asia. Async by default, live sessions when they matter.
		</p>
	</section>
</ContentLayout>
