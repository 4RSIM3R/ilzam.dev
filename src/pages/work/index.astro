---
import ContentLayout from '@/layouts/content-layout.astro'

const caseStudies = [
	{
		title: "kotakpasir",
		subtitle: "Self-hosted sandboxes for AI agents. Hardened Docker, YAML policy, and a control plane that runs on a $5 VPS.",
		label: "Open Source / Infra",
		region: "MIT, Pre-1.0",
		year: "2026, ongoing",
		slug: "kotakpasir-agent-sandboxes",
		stack: ["Go", "Docker", "Fiber v3", "SQLite", "MCP", "Prometheus"],
	},
	{
		title: "Dapo Vokasi",
		subtitle: "Unifying vocational teacher data across 7 national training centers.",
		label: "Government Tech",
		region: "Indonesia",
		year: "2024 - 2025",
		slug: "dapo-vokasi-data-platform",
		stack: ["Laravel", "Inertia.js", "React.js", "SQL Server", "ETL Pipeline"],
	},
]
---

<ContentLayout
	title="Things I've Shipped — Ilzam"
	description="Case studies from 15+ MVPs shipped across marketplaces, SaaS, AI pipelines, and government systems. Most details are under NDA — here's what I can share."
>
	<h1 class="text-4xl font-light leading-tight tracking-tight md:text-5xl">
		Things I've Shipped
	</h1>
	<p class="mt-4 text-muted-foreground">
		Most details are under NDA. Here's what I can share.
	</p>

	<div class="mt-12 grid gap-6">
		{caseStudies.map((study) => (
			<a href={`/work/${study.slug}`} class="group block rounded-lg border p-5 transition-shadow hover:shadow-md">
				<div class="flex items-center justify-between">
					<span class="rounded-sm bg-muted px-2 py-0.5 text-xs font-medium uppercase">{study.label}</span>
					<span class="text-xs text-muted-foreground">{study.region} / {study.year}</span>
				</div>
				<h2 class="mt-3 text-lg font-semibold group-hover:underline">{study.title}</h2>
				<p class="mt-1 text-sm text-muted-foreground">{study.subtitle}</p>
				<div class="mt-3 flex flex-wrap gap-1.5">
					{study.stack.map((tech) => (
						<span class="rounded-full border px-2 py-0.5 text-xs">{tech}</span>
					))}
				</div>
			</a>
		))}
	</div>

	<div class="mt-12 rounded-lg bg-muted/50 p-6 text-center">
		<p class="font-medium">Working on something that could be next?</p>
		<p class="mt-1 text-sm text-muted-foreground">
			Book a free 30-minute intro call. No pitch, no pressure.
		</p>
		<a
			href="https://cal.com/ilzam/intro"
			target="_blank"
			rel="noopener noreferrer"
			class="mt-4 inline-block rounded-full bg-foreground px-5 py-2 text-sm font-medium text-background transition-opacity hover:opacity-90"
		>
			Book a Call
		</a>
	</div>
</ContentLayout>
