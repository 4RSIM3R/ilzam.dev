---
import ContentLayout from '@/layouts/content-layout.astro'

const notes = [
	{
		title: "How to Build Your Startup's Website in 2026",
		slug: "how-to-build-startup-website-2026",
		category: "Founder Decisions",
		description: "WordPress, Webflow, Next.js, or Astro? A real comparison, and how this site was actually built.",
	},
	{
		title: "I Built an AI Agent That Runs Untrusted Code to Find Security Threats",
		slug: "ai-security-scanner-upstash-box",
		category: "Engineering",
		description: "877,000 malicious packages and counting. I used Upstash Box to build a sandboxed AI security scanner that does both static and dynamic analysis.",
	},
]

const categories = [...new Set(notes.map(n => n.category))]
---

<ContentLayout
	title="Field Notes — Ilzam"
	description="Things I've figured out in production — written down so you don't have to figure them out the hard way. Technical deep-dives, founder decision frameworks, and stack comparisons."
>
	<h1 class="text-4xl font-light leading-tight tracking-tight md:text-5xl">
		Field Notes
	</h1>
	<p class="mt-4 text-muted-foreground">
		Things I've figured out in production — written down so you don't have to figure them out the hard way.
	</p>

	{categories.map((category) => (
		<section class="mt-12">
			<h2 class="text-sm font-medium uppercase tracking-wider text-muted-foreground">{category}</h2>
			<div class="mt-4 grid gap-4">
				{notes.filter(n => n.category === category).map((note) => (
					<a href={`/notes/${note.slug}`} class="group block rounded-lg border p-5 transition-shadow hover:shadow-md">
						<h3 class="font-semibold group-hover:underline">{note.title}</h3>
						<p class="mt-1 text-sm text-muted-foreground">{note.description}</p>
					</a>
				))}
			</div>
		</section>
	))}

	<section class="mt-12 rounded-lg bg-muted/50 p-6 text-center">
		<p class="font-medium">Not sure what to build or how to build it?</p>
		<p class="mt-1 text-sm text-muted-foreground">
			That's exactly what the advisory session is for.
		</p>
		<a
			href="https://cal.com/ilzam/intro"
			target="_blank"
			rel="noopener noreferrer"
			class="mt-4 inline-block rounded-full bg-foreground px-5 py-2 text-sm font-medium text-background transition-opacity hover:opacity-90"
		>
			Book an Advisory Session
		</a>
	</section>
</ContentLayout>
